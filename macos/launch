#!/bin/bash
# macOS .app launcher — opens a file picker for .ipynb/.py notebook files,
# then runs with uvx juv run (Jupyter) or uvx marimo edit --sandbox (marimo).

APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

# Check if a notebook exists next to the .app (skip picker if so)
NOTEBOOK=""
for f in "$APP_DIR"/*.ipynb "$APP_DIR"/*.py; do
  [ -f "$f" ] && NOTEBOOK="$f" && break
done

if [ -z "$NOTEBOOK" ]; then
  # Show file picker for .ipynb and .py files
  NOTEBOOK=$(osascript -e 'try
    set theFile to choose file with prompt "Select a notebook (.ipynb or .py):" of type {"public.item"} default location (path to home folder)
    return POSIX path of theFile
  on error
    return ""
  end try' 2>/dev/null)

  if [ -z "$NOTEBOOK" ]; then
    exit 0
  fi

  # Verify it's a supported file type
  case "$NOTEBOOK" in
    *.ipynb|*.py) ;;
    *)
      osascript -e 'display alert "Error" message "Please select a .ipynb or .py file."'
      exit 1
      ;;
  esac
fi

NOTEBOOK_DIR="$(dirname "$NOTEBOOK")"
NOTEBOOK_NAME="$(basename "$NOTEBOOK")"

# Choose the right command based on file extension
case "$NOTEBOOK_NAME" in
  *.ipynb) RUN_CMD="uvx juv run" ;;
  *.py)    RUN_CMD="uvx marimo edit --sandbox" ;;
esac

# Write a temp runner script to avoid escaping issues with osascript
RUNNER=$(mktemp /tmp/notebook-launcher-runner.XXXXXX)
cat > "$RUNNER" << SCRIPT
#!/bin/bash
export PATH="\$HOME/.local/bin:\$PATH"
if ! command -v uv >/dev/null 2>&1; then
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="\$HOME/.local/bin:\$PATH"
fi
cd "$NOTEBOOK_DIR"
echo "Launching $NOTEBOOK_NAME ..."
$RUN_CMD "$NOTEBOOK_NAME"
rm -f "$RUNNER"
SCRIPT
chmod +x "$RUNNER"

osascript -e "tell application \"Terminal\"
  activate
  do script \"'${RUNNER}'\"
end tell"
